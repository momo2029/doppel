{
  "id": "xiaohongshu-automate",
  "name_cn": "小红书自动化",
  "name_en": "小红书 Auto",
  "description_cn": "自动巡逻小红书，AI 智能回复和点赞",
  "description_en": "Auto-patrol 小红书, AI-powered replies and likes",
  "type": "community",
  "version": "1.0.0",
  "author": "蟹蟹官方",
  "lang": "zh-CN",
  "rule": {
    "capabilities": {
      "automate": true
    },
    "match": {
      "urlPatterns": [
        "*://www.xiaohongshu.com/*",
        "*://xiaohongshu.com/*"
      ]
    },
    "pageTypes": [
      {
        "name": "home",
        "priority": 10,
        "conditions": {
          "urlMatch": "^https?://(www\\.)?xiaohongshu\\.com/(explore)?$"
        }
      },
      {
        "name": "detail",
        "priority": 30,
        "conditions": {
          "or": [
            {
              "urlMatch": "/explore/[a-z0-9]+(\\?|$)"
            },
            {
              "hashContains": "#/note/"
            },
            {
              "selector": ".note-detail-mask, .note-scroller"
            }
          ]
        }
      },
      {
        "name": "search",
        "priority": 20,
        "conditions": {
          "urlContains": [
            "/search_result"
          ]
        }
      },
      {
        "name": "profile",
        "priority": 25,
        "conditions": {
          "urlContains": [
            "/user/profile/"
          ]
        }
      }
    ],
    "extractors": {
      "lists": {
        "home": {
          "container": ".feeds-page, .explore-feed",
          "item": "section.note-item",
          "fields": {
            "title": {
              "selector": ".title",
              "transform": "trim"
            },
            "url": {
              "selector": "a.cover",
              "attribute": "href",
              "transform": "absoluteUrl"
            },
            "author": {
              "selector": ".author-wrapper .name",
              "transform": "trim"
            },
            "likes": {
              "selector": ".like-wrapper .count",
              "transform": "parseCount"
            }
          }
        }
      },
      "detail": {
        "title": {
          "selector": "#detail-desc .note-text, .note-content .desc .note-text",
          "transform": "trim"
        },
        "author": {
          "selector": ".author-container .username, .note-scroller .author-wrapper .username",
          "transform": "trim"
        },
        "content": {
          "selector": "#detail-desc .note-text, .note-content .desc .note-text"
        },
        "likes": {
          "selector": ".engage-bar .like-wrapper .count, .note-scroller .like-wrapper .count",
          "transform": "parseCount"
        },
        "collects": {
          "selector": ".engage-bar .collect-wrapper .count, .note-scroller .collect-wrapper .count",
          "transform": "parseCount"
        },
        "comments": {
          "selector": ".engage-bar .chat-wrapper .count, .note-scroller .chat-wrapper .count",
          "transform": "parseCount"
        },
        "isLiked": {
          "selector": ".engage-bar .like-wrapper.liked, .engage-bar .like-icon.active",
          "transform": "exists"
        },
        "isCollected": {
          "selector": ".engage-bar .collect-wrapper.collected, .engage-bar .collect-icon.active",
          "transform": "exists"
        },
        "replies": {
          "container": ".comments-container",
          "item": ".parent-comment .comment-item:not(.comment-item-sub)",
          "fields": {
            "author": {
              "selector": ".author-wrapper .name",
              "transform": "trim"
            },
            "content": {
              "selector": ".content .note-text"
            },
            "likes": {
              "selector": ".like-wrapper .count",
              "transform": "parseCount"
            },
            "isLiked": {
              "selector": ".like-wrapper.liked",
              "transform": "exists"
            }
          }
        }
      },
      "currentUser": {
        "selector": ".user-info .name, .sidebar-user .name",
        "transform": "trim"
      }
    },
    "actions": {
      "clickPost": {
        "selector": "section.note-item a.cover"
      },
      "reply": {
        "input": {
          "selector": "#content-textarea",
          "type": "contenteditable"
        },
        "submit": {
          "selector": ".input-box .submit-btn, .comment-input .submit, button.submit",
          "fallback": "enter",
          "waitAfterClick": 2000
        }
      },
      "like": {
        "selector": ".engage-bar .like-wrapper, .note-scroller .like-wrapper",
        "activeSelector": ".like-wrapper.liked, .like-icon.active",
        "waitAfterClick": 500
      },
      "likeComment": {
        "selector": ".comment-item .like-wrapper, .comment-item .like",
        "activeSelector": ".like-icon.active",
        "waitAfterClick": 500
      },
      "collect": {
        "selector": ".engage-bar .collect-wrapper, .note-scroller .collect-wrapper",
        "activeSelector": ".collect-wrapper.collected, .collect-icon.active",
        "waitAfterClick": 500
      },
      "follow": {
        "selector": ".note-detail-follow-btn:not(.followed), .author-container .follow-btn:not(.followed)",
        "waitAfterClick": 1000
      },
      "closeDetail": {
        "selector": ".note-detail-mask .close-circle, .close-btn",
        "fallback": {
          "selector": ".note-detail-mask",
          "action": "click"
        }
      }
    },
    "contentProcessing": {
      "cleanup": {
        "removeSelectors": [
          ".expand",
          ".toolbar",
          ".more-btn"
        ],
        "maxLength": 2000
      },
      "parseCount": {
        "pattern": "([0-9.]+)万?",
        "multiplier": {
          "万": 10000
        }
      }
    },
    "onboarding": {
      "startUrl": "https://www.xiaohongshu.com/explore",
      "loginCheck": {
        "selector": ".user-info .name, .sidebar-user .name",
        "urlNotContains": "/login"
      },
      "loginUrl": "https://www.xiaohongshu.com/login",
      "loginHint": "请先登录小红书账号"
    },
    "options": {
      "supportedActions": [
        "reply",
        "like",
        "collect",
        "follow"
      ],
      "delays": {
        "afterPageLoad": [
          3000,
          5000
        ],
        "afterClick": [
          1000,
          2000
        ],
        "afterReply": [
          2000,
          4000
        ]
      },
      "patrolModes": [
        {
          "value": "home",
          "label": "首页推荐",
          "startUrl": "https://www.xiaohongshu.com/explore"
        },
        {
          "value": "movie_tv",
          "label": "影视",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.movie_and_tv_v3"
        },
        {
          "value": "food",
          "label": "美食",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.food_v3"
        },
        {
          "value": "travel",
          "label": "旅行",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.travel_v3"
        },
        {
          "value": "fashion",
          "label": "穿搭",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.fashion_v3"
        },
        {
          "value": "fitness",
          "label": "健身",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.fitness_v3"
        },
        {
          "value": "cosmetics",
          "label": "彩妆",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.cosmetics_v3"
        },
        {
          "value": "digital",
          "label": "数码",
          "startUrl": "https://www.xiaohongshu.com/explore?channel_id=homefeed.digital_v3"
        }
      ]
    }
  }
}